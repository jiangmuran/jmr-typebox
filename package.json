{
  "name": "typebox",
  "private": true,
  "version": "1.0.0",
  "description": "Lightweight Markdown editor & format converter. No login, works offline.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-assets.js && vite-ssg build && node scripts/gen-sitemap.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "postinstall": "node scripts/copy-assets.js"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@codemirror/lang-python": "^6.2.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@turbodocx/html-to-docx": "^1.22.0",
    "@unhead/vue": "^2.1.15",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "marked": "^18.0.0",
    "pdfjs-dist": "^6.0.227",
    "pyodide": "^314.0.0",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.1.0",
    "vite": "^6.3.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  }
}
